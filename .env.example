# Database (Render injects DATABASE_URL from quickstay-db)
DATABASE_URL=postgresql://quickstay:password@host:5432/quickstay
SPRING_DATASOURCE_USERNAME=quickstay
SPRING_DATASOURCE_PASSWORD=your_db_password

# Auth
JWT_SECRET_KEY=change_me_min_32_chars_random_string_here

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# App
SPRING_PROFILES_ACTIVE=prod
PORT=8080
FRONTEND_URL=https://quickstay-web-princesatapathy.onrender.com
MANAGER_SIGNUP_CODE=secret_onboarding_code

# Frontend
VITE_API_BASE_URL=https://quickstay-api-princesatapathy.onrender.com/api/v1
