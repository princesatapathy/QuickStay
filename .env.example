# ── Database (Railway injects these automatically via PostgreSQL add-on) ──
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/quickstay
PGHOST=localhost
PGPORT=5432
PGDATABASE=quickstay
PGUSER=postgres
PGPASSWORD=your_db_password

# ── Auth ──
JWT_SECRET_KEY=change_me_min_32_chars_random_string_here

# ── Razorpay ──
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# ── App ──
SPRING_PROFILES_ACTIVE=prod
PORT=8080
FRONTEND_URL=https://your-frontend.vercel.app
MANAGER_SIGNUP_CODE=secret_onboarding_code
